# Copy to .env (gitignored) and fill in. Loaded by scripts/dev-serverless.sh.
RUNPOD_ENDPOINT_ID=your_endpoint_id
RUNPOD_API_KEY=your_runpod_api_key

# WORLDSKETCH_PUBLIC_URL is set automatically by dev-serverless.sh from the cloudflare
# tunnel it launches. Only set it here for a fixed public coordinator (e.g. prod).
# WORLDSKETCH_PUBLIC_URL=https://your-public-host

# --- Tunable pipeline params (defaults shown) ---------------------------------
# These are read by the pipeline code, so set them WHERE THE PIPELINE RUNS:
#   - serverless: on the RunPod endpoint's env settings (the worker runs the pipeline)
#   - local mode: here in .env (the coordinator runs the pipeline)
# Changing them needs NO image rebuild — they take effect on the next run.
#
# Image generation (ComfyUI):
# WS_STEPS=7
# WS_CFG=6.5
# WS_DENOISE=0.5
# WS_CANNY_STRENGTH=0.9
# WS_DEPTH_STRENGTH=0.6
#
# World expansion (decorate new objects to match an existing plot — see
# docs/world-expansion-plan.md). Only used when a scene carries a parent job id.
# WS_EXPAND_DENOISE=0.8            # img2img strength inside the new-object mask (the frozen world is untouched regardless)
# WS_EXPAND_MASK_GROW=6           # px to dilate the mask so new objects blend at the seam
#
# Fusion / culls (raise these to keep more points = fewer holes):
# WS_DEDUPE=0.025                 # smaller = denser point cloud
# WS_SPARSE_VOXEL=0.1
# WS_SPARSE_MIN_NEIGHBORS=4       # lower = keeps sparser points (fewer holes)
# WS_COLOR_CULL_THRESHOLD=0.8     # 0-1; higher = cull fewer off-colour points
