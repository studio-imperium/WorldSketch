# === API keys ===
OPENAI_API_KEY=
TRIPOSPLAT_URL=
# WS_GEMINI_ENV_FILE=/absolute/path/to/.env

# === Runtime ===
WS_SAVE_GENERATIONS=true
WS_OUTPUT_DIR=outputs

# === Whole-scene image edit (one capture -> one textured scene image) ===
WS_SCENE_IMAGE_PROVIDER=openai
WS_SCENE_SKIP_IMAGE_EDIT=false
WS_SCENE_IMAGE_MODEL=gpt-image-1
WS_SCENE_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
WS_SCENE_IMAGE_SIZE=1024x1024
WS_SCENE_IMAGE_QUALITY=high
WS_SCENE_IMAGE_FIDELITY=high
WS_SCENE_IMAGE_BACKGROUND=opaque
WS_SCENE_IMAGE_FORMAT=png

# === Whole-scene TripoSplat (one textured scene image -> one splat) ===
WS_SCENE_TRIPO_STEPS=24
WS_SCENE_TRIPO_GUIDANCE=7
WS_SCENE_TRIPO_GAUSSIANS=262144
WS_SCENE_TRIPO_FORMAT=splat
WS_SCENE_OPACITY_FLOOR=0.03
WS_SCENE_Y_OFFSET=0
WS_SCENE_YAW=180
WS_SCENE_FIT_BBOX_PERCENTILE=0
