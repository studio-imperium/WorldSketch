# === API keys ===
OPENAI_API_KEY=
TRIPOSPLAT_URL=
# WS_GEMINI_ENV_FILE=/absolute/path/to/.env

# === Debug / workflow toggles ===
WS_SAVE_GENERATIONS=true
WS_SINGLE_OBJECT=false
WS_OBJECTS_ONLY=false
WS_FLOOR_ONLY=false
WS_IDENTIFY_ONLY=false
WS_GEN_CONCURRENCY=4
WS_OUTPUT_DIR=outputs

# === Identification ===
WS_GEMINI_IDENTIFY_MODEL=gemini-2.5-flash

# === Object image edit ===
WS_OBJECT_IMAGE_PROVIDER=openai
WS_OBJECT_SKIP_IMAGE_EDIT=false
WS_OBJECT_IMAGE_MODEL=gpt-image-1-mini
WS_OBJECT_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
WS_OBJECT_IMAGE_SIZE=1024x1024
WS_OBJECT_IMAGE_QUALITY=medium
WS_OBJECT_IMAGE_FIDELITY=low
WS_OBJECT_IMAGE_BACKGROUND=transparent
WS_OBJECT_IMAGE_FORMAT=png

# === Object TripoSplat ===
WS_OBJECT_TRIPO_STEPS=10
WS_OBJECT_TRIPO_GUIDANCE=3
WS_OBJECT_TRIPO_GAUSSIANS=32768
WS_OBJECT_TRIPO_FORMAT=splat

# === Object fitting / palette ===
WS_OBJECT_PALETTE_MATCH=lock
WS_OBJECT_PALETTE_MATCH_STRENGTH=0.7
WS_OBJECT_PALETTE_MATCH_LIGHTNESS=0.4
WS_OBJECT_OPACITY_FLOOR=0.1
WS_OBJECT_Y_OFFSET=0
WS_OBJECT_YAW=90
WS_OBJECT_FIT_CLAMP_K=1
WS_OBJECT_FIT_BBOX_PERCENTILE=0

# === Floor image edit ===
WS_FLOOR_IMAGE_PROVIDER=openai
WS_FLOOR_SKIP_IMAGE_EDIT=false
WS_FLOOR_IMAGE_MODEL=gpt-image-1
WS_FLOOR_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
WS_FLOOR_IMAGE_SIZE=1024x1024
WS_FLOOR_IMAGE_QUALITY=medium
WS_FLOOR_IMAGE_FIDELITY=high
WS_FLOOR_IMAGE_BACKGROUND=transparent
WS_FLOOR_IMAGE_FORMAT=png

# === Floor TripoSplat ===
WS_FLOOR_TRIPO_STEPS=14
WS_FLOOR_TRIPO_GUIDANCE=3
WS_FLOOR_TRIPO_GAUSSIANS=65536
WS_FLOOR_TRIPO_FORMAT=splat

# === Floor fitting / palette ===
WS_FLOOR_PALETTE_MATCH=lock
WS_FLOOR_PALETTE_MATCH_STRENGTH=0.7
WS_FLOOR_PALETTE_MATCH_LIGHTNESS=0.4
WS_FLOOR_OPACITY_FLOOR=0.1
WS_FLOOR_Y_OFFSET=0
WS_FLOOR_YAW=90
WS_FLOOR_FIT_CLAMP_K=1
WS_FLOOR_FIT_BBOX_PERCENTILE=0