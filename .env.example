OPENAI_API_KEY=
TRIPOSPLAT_URL=

# Image edit backend: openai (gpt-image-1-mini, default — the cheap path) or gemini
# (2.5 Flash Image). Each subject is re-textured alone on a black background, and the
# client sends only the guide image (one input) to keep the per-call cost down.
WS_IMAGE_PROVIDER=openai
WS_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Gemini key: GEMINI_API_KEY env wins, else read from this .env (default: ../Viggle/Backend/.env).
# WS_GEMINI_ENV_FILE=/absolute/path/to/.env

# Strictness knobs for the gpt-image edit (openai provider). Set any to "" to omit.
# gpt-image-1-mini ~$0.005 (low-quality 1024 output) + ~$0.0015 per 1024 input image.
WS_IMAGE_MODEL=gpt-image-1-mini
WS_IMAGE_SIZE=1024x1024          # gpt-image-1 family minimum; 512 is not supported
WS_IMAGE_QUALITY=low
WS_IMAGE_FIDELITY=low            # ONLY applies to the full gpt-image-1 model (mini / 1.5 / 2 reject input_fidelity, so it is never sent for them). low = cheapest; high adds ~4160 input tokens/image.

# The floor is the one subject we don't skimp on: it uses the full gpt-image-1 with
# high input fidelity so the painted terrain layout is preserved precisely. Objects
# keep the cheap WS_IMAGE_MODEL above. (~$0.06 per floor, once per world.)
WS_FLOOR_IMAGE_MODEL=gpt-image-1
WS_FLOOR_IMAGE_FIDELITY=high
WS_IMAGE_BACKGROUND=opaque       # subjects are captured on black; keep the edit opaque, not transparent
WS_IMAGE_FORMAT=png
# Skip the image edit and feed the raw block-out capture straight to Tripo (debug).
WS_SKIP_IMAGE_EDIT=false

# TripoSplat. Steps are sized per object by volume on the client (tiny props get a
# cheap 2-3 steps); WS_TRIPO_STEPS is the fallback when the client sends none.
WS_TRIPO_STEPS=24
WS_TRIPO_GUIDANCE=7
WS_TRIPO_GAUSSIANS=32768
WS_TRIPO_FORMAT=splat

# Per-world generations are saved under outputs/NNNN/ (one folder per world, with
# <name>-input.png / <name>-output.png / <name>.splat per object + the floor).
WS_SAVE_GENERATIONS=true
WS_OUTPUT_DIR=outputs
