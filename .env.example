OPENAI_API_KEY=
TRIPOSPLAT_URL=
WS_IMAGE_MODEL=gpt-image-1
WS_IMAGE_SIZE=1024x1024
# Strictness knobs for the gpt-image edit. Set any to "" to omit the field.
WS_IMAGE_QUALITY=low
WS_IMAGE_FIDELITY=low
WS_IMAGE_BACKGROUND=transparent
WS_IMAGE_FORMAT=png
WS_TRIPO_STEPS=30
WS_TRIPO_GUIDANCE=3.5
WS_TRIPO_GAUSSIANS=100000
WS_TRIPO_FORMAT=splat
# Save (input, prompt -> output) GPT-image pairs for finetuning. Default on.
WS_SAVE_GENERATIONS=true
WS_OUTPUT_DIR=server/output

# Splat cull/fit knobs (served to the client via /api/config; no rebuild needed,
# just restart the server + regenerate). Lower = harsher unless noted.
# Protected core: opacity + density culls below ONLY apply to splats outside this
# distance-from-center percentile. 1.0 = protect everything (opacity+density off).
WS_CULL_RADIUS_PCT=0.9      # inner 90% by distance is immune to culling; lower = harsher
WS_CULL_OPACITY=0.04        # (periphery only) drop gaussians below this opacity (haze/fog)
WS_CULL_DENSITY_CELLS=28    # density voxel-grid resolution
WS_CULL_DENSITY_FRAC=0.08   # (periphery only) cell "occupied" if it holds >= this fraction of the peak cell
WS_CULL_HEIGHT_CAP=1.8      # max kept height as a multiple of footprint span
WS_CULL_BELOW_GROUND=0.12   # keep this much below the ground plane (roots/dirt)
WS_CULL_GROUND_PCT=0.92     # stored-Y percentile used as the ground plane for the height window
WS_CULL_FLOOR_PCT=0.97      # height percentile grounded to the floor; <1 ignores a sparse tail below the base, 1.0 = literal lowest gaussian
WS_CULL_FLOOR_Y=0           # plot-local Y the floor is grounded to
WS_CULL_INSET=0.98          # shrink the footprint slightly so corners sit inside the plot
WS_CULL_POST_SCALE=1.0      # extra uniform scale applied AFTER corner-fit (>1 overflows, <1 shrinks)
WS_CULL_DEBUG=false         # log per-generation cull stats to the browser console
