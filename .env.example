# The OAuth client ID is public. Never put a Hugging Face access token or client secret here.
WS_HF_OAUTH_CLIENT_ID=91581ad0-d16c-4f49-9746-cff21b50ac9e

# Leave blank locally. In production, set this to the exact HTTPS URL registered in the
# Hugging Face OAuth app, including its trailing slash (for example https://app.example.com/).
WS_HF_REDIRECT_URL=

# Public ZeroGPU Spaces used directly from each signed-in user's browser.
WS_HF_IMAGE_SPACE=black-forest-labs/FLUX.2-klein-4B
WS_HF_TRIPO_SPACE=VAST-AI/TripoSplat

# Optional image-detail route used only when the user enables inference credits.
WS_HF_INFERENCE_PROVIDER=fal-ai
WS_HF_INFERENCE_MODEL=black-forest-labs/FLUX.2-klein-4B

# Final-quality defaults, using half of TripoSplat's maximum gaussian budget.
WS_HF_IMAGE_STEPS=4
WS_HF_IMAGE_GUIDANCE=1
WS_HF_IMAGE_WIDTH=1024
WS_HF_IMAGE_HEIGHT=1024
WS_HF_TRIPO_STEPS=20
WS_HF_TRIPO_GUIDANCE=3
WS_HF_TRIPO_GAUSSIANS=131072

# Existing splat fitting controls.
WS_SCENE_OPACITY_FLOOR=0.03
WS_SCENE_Y_OFFSET=0
WS_SCENE_YAW=0
WS_SCENE_FIT_BBOX_PERCENTILE=0
