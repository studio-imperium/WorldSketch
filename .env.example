OPENAI_API_KEY=
TRIPOSPLAT_URL=
WS_IMAGE_MODEL=gpt-image-1
WS_IMAGE_SIZE=1024x1024
# Strictness knobs for the gpt-image edit. Set any to "" to omit the field.
WS_IMAGE_QUALITY=low
WS_IMAGE_FIDELITY=high
WS_IMAGE_BACKGROUND=transparent
WS_IMAGE_FORMAT=png
WS_TRIPO_STEPS=24
WS_TRIPO_GUIDANCE=7
WS_TRIPO_GAUSSIANS=32768
WS_TRIPO_FORMAT=splat
# Save (input, prompt -> output) GPT-image pairs for finetuning. Default on.
WS_SAVE_GENERATIONS=true
WS_OUTPUT_DIR=server/output

# Splat cull/fit knobs (served to the client via /api/config; no rebuild needed,
# just restart the server + regenerate). Three knobs, one per pipeline stage:
#   cull (discard backdrop/noise) -> seat (find + pin the floor) -> fit (size into plot).
# The client expands strength into the underlying per-stage params (deriveCull).
WS_CULL_STRENGTH=0     # 0 = keep everything, 1 = harshest cull. 0.6 = the hand-tuned baseline.
WS_CULL_FLOOR_PCT=0.97 # ground-detection percentile; lower seats the floor higher into the cloud.
WS_CULL_FIT=3          # render scale vs the plot footprint; 1.0 = true 1:1 (8x8).
WS_CULL_Y_OFFSET=0.45  # plot-local Y nudge applied AFTER all transforms (+ = up; plot is 8 units).
WS_FIND_FLOOR_MODE=none # floor detection: surface (robust median of column-tops) | surface_min (lowest exposed top) | percentile (legacy global quantile); anything else (e.g. none) = surface median.
WS_FLOOR_CULL_STRENGTH=1 # analysis-only cull strength used JUST to measure the floor (strips backdrop/sub-ground); does NOT cull the rendered splat. 0 = measure on the full cloud.
WS_FLOOR_SURFACE_SIGMA=10 # seat the splat's visible SURFACE on the floor: offset the seat by N sigma of the floor gaussians' vertical radius. 0 = seat gaussian centers (ground hovers above).
WS_SEAT_FLOOR=true # pin the detected floor to the plot floor plane. false = bypass ALL floor logic, just vertically-center the content (debug/test).
WS_CULL_DEBUG=false    # log per-generation cull + orientation stats to the browser console

# Orientation recovery: Tripo lands the splat at an arbitrary axis-aligned pose.
# Default path aligns the splat to the colliders (height-map + colour). Markers are
# an off-by-default fallback for symmetric scenes (they bake colour tags into the
# splat that must be culled, so leave off unless the collider scorer struggles).
WS_ORIENT=false          # rotate/reflect the splat into plot-local space (false = leave as-is).
WS_ORIENT_MARKER=false  # bake corner fiducials into the capture (else align to colliders).
WS_SPLAT_ROTATE=1       # final manual yaw applied AFTER everything: 1|2|3|4 -> 90*n deg about plot centre (4 = none).
