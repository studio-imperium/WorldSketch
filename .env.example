OPENAI_API_KEY=
TRIPOSPLAT_URL=

# Image edit backend: openai (gpt-image-1-mini, default — the cheap path) or gemini
# (2.5 Flash Image). Each subject is re-textured alone on a black background, and the
# client sends only the guide image (one input) to keep the per-call cost down.
WS_IMAGE_PROVIDER=openai
WS_GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Identification phase (always Gemini, regardless of WS_IMAGE_PROVIDER): a vision model
# names each numbered object from a whole-world context capture. Needs the Gemini key.
WS_GEMINI_IDENTIFY_MODEL=gemini-2.5-flash
# Gemini key: GEMINI_API_KEY env wins, else read from this .env (default: ../Viggle/Backend/.env).
# WS_GEMINI_ENV_FILE=/absolute/path/to/.env

# Strictness knobs for the gpt-image edit (openai provider). Set any to "" to omit.
# gpt-image-1-mini ~$0.005 (low-quality 1024 output) + ~$0.0015 per 1024 input image.
WS_IMAGE_MODEL=gpt-image-1-mini
WS_IMAGE_SIZE=1024x1024          # gpt-image-1 family minimum; 512 is not supported
WS_IMAGE_QUALITY=low
WS_IMAGE_FIDELITY=low            # ONLY applies to the full gpt-image-1 model (mini / 1.5 / 2 reject input_fidelity, so it is never sent for them). low = cheapest; high adds ~4160 input tokens/image.

# The floor is the one subject we don't skimp on: it uses the full gpt-image-1 with
# high input fidelity so the painted terrain layout is preserved precisely. Objects
# keep the cheap WS_IMAGE_MODEL above. (~$0.06 per floor, once per world.)
WS_FLOOR_IMAGE_MODEL=gpt-image-1
WS_FLOOR_IMAGE_FIDELITY=high
WS_IMAGE_BACKGROUND=opaque       # subjects are captured on black; keep the edit opaque, not transparent
WS_IMAGE_FORMAT=png
# Skip the image edit and feed the raw block-out capture straight to Tripo (debug).
WS_SKIP_IMAGE_EDIT=false

# Palette correction: pull the re-textured image back toward the block-out's colours so the
# model can't drift the intended hues/tone. WS_PALETTE_MATCH = off | global (whole-image
# CIELAB chroma transfer) | lock (snap each pixel's hue to the nearest block-out colour).
# WS_PALETTE_MATCH_STRENGTH in [0,1] scales that hue match. WS_PALETTE_MATCH_LIGHTNESS in
# [0,1] separately forces lightness toward the block-out's own per-pixel lightness: 0 = leave
# the model's lightness, 1 = flat onto the block-out (no light/dark variation). Independent of
# the hue mode, so it also applies in lock mode.
WS_PALETTE_MATCH=off
WS_PALETTE_MATCH_STRENGTH=0.75
WS_PALETTE_MATCH_LIGHTNESS=0

# TripoSplat. Steps are sized per object by volume on the client (tiny props get a
# cheap 2-3 steps); WS_TRIPO_STEPS is the fallback when the client sends none.
WS_TRIPO_STEPS=24
WS_TRIPO_GUIDANCE=7
WS_TRIPO_GAUSSIANS=32768
WS_TRIPO_FORMAT=splat
# Objects use a fixed, cheap Tripo budget (the floor keeps WS_TRIPO_STEPS/GUIDANCE).
OBJECT_STEPS=3
OBJECT_GUIDANCE=2
# Plot-local Y nudge applied to seated OBJECTS, after fit+seat+yaw (+ = up). 0 = none.
WS_CULL_Y_OFFSET=0
# Drop gaussians below this opacity [0,1] when seating a splat — raise to kill wisps/haze.
WS_OPACITY_FLOOR=0.1
# Post-generation yaw (degrees) applied to seated splats about their centre — dial in a
# turned reconstruction. Objects and the floor are tunable independently.
WS_OBJECT_YAW=0
WS_FLOOR_YAW=0
# Subjects re-textured + reconstructed in parallel (captures stay serial). Higher = faster
# but bounded by image-API rate limits + the Tripo server's concurrency. 1 = sequential.
WS_GEN_CONCURRENCY=4

# Per-world generations are saved under outputs/NNNN/ (one folder per world, with
# <name>-input.png / <name>-output.png / <name>.splat per object + the floor).
WS_SAVE_GENERATIONS=true
WS_OUTPUT_DIR=outputs

# Debug: generate only the first object and skip the floor + other objects, for fast
# object-generation testing. Surfaced to the client via GET /api/config.
WS_SINGLE_OBJECT=false
# Debug: generate every object but SKIP the floor (the painted ground stays a primitive),
# for testing objects without waiting on the floor.
WS_OBJECTS_ONLY=false
# Debug: generate ONLY the floor and skip every object, for fast floor testing.
WS_FLOOR_ONLY=false
# Debug: run ONLY the Gemini identification phase and stop — logs the numbered graphic +
# labels to outputs/NNNN/ and generates nothing (no floor, no objects, no Tripo).
WS_IDENTIFY_ONLY=false
